# Force UTF-8 and LF for all text files
* text=auto eol=lf

# Explicitly mark these as text
*.py text eol=lf
*.md text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.db binary
*.sqlite binary
