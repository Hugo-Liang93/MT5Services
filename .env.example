# ============================================
# MT5Services 环境变量模板（精简版）
# ============================================
# 说明：
# 1) 项目主配置来源是 config/*.ini 与 config/indicators.json
# 2) 环境变量只用于“敏感信息”或“临时覆盖”
# 3) 复制为 .env 后按需修改：cp .env.example .env

# --------------------------------------------
# API 运行时临时覆盖（可选）
# --------------------------------------------
# 覆盖 config/market.ini 的 host/port
MT5_API_HOST=0.0.0.0
MT5_API_PORT=8808

# 若开启 auth_enabled=true，建议优先通过环境变量提供 API Key
MT5_API_KEY=replace_with_secure_api_key

# --------------------------------------------
# 经济日历外部数据源密钥（可选）
# --------------------------------------------
TRADINGECONOMICS_API_KEY=
FRED_API_KEY=

# --------------------------------------------
# 兼容层 / 旧管理器可读取的变量（可选）
# --------------------------------------------
# 这些变量主要用于 src/config/advanced_manager.py 的兼容路径，
# 正常运行建议优先修改 config/app.ini
MT5_SYMBOLS=XAUUSD,EURUSD
MT5_TIMEFRAMES=M1,H1
MT5_DEFAULT_SYMBOL=XAUUSD
TICK_INTERVAL=0.5
OHLC_INTERVAL=30.0
LOG_LEVEL=INFO
INDICATOR_POLL_SECONDS=5
INDICATOR_RELOAD_INTERVAL=60
