# ============================================
# MT5Services 环境变量配置模板
# ============================================

# MT5 连接配置
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=YourBroker-Server
MT5_PATH="C:/Program Files/MetaTrader 5/terminal64.exe"  # Windows 路径示例
# MT5_PATH="/Applications/MetaTrader 5.app/Contents/MacOS/terminal"  # macOS 路径示例

# 数据库配置 (PostgreSQL/TimescaleDB)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres_password
PG_DATABASE=mt5
PG_SCHEMA=public
PG_SSLMODE=disable  # 生产环境建议使用 require/verify-full

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=False
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# 应用基础配置
DEFAULT_SYMBOL=EURUSD
TIMEZONE=UTC
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
API_HOST=0.0.0.0
API_PORT=8808
ENABLE_CORS=true
API_KEY=your_api_key_here  # 用于 API 认证

# 数据采集配置
INGEST_SYMBOLS=EURUSD,XAUUSD,GBPUSD,USDJPY
INGEST_TICK_INTERVAL=0.5  # Tick 采集间隔（秒）
INGEST_OHLC_TIMEFRAMES=M1,M5,M15,H1,H4,D1
INGEST_OHLC_INTERVAL=30.0  # OHLC 采集间隔（秒）
INGEST_ENABLED=true

# 缓存配置
TICK_CACHE_SIZE=5000
OHLC_CACHE_LIMIT=500
QUOTE_STALE_SECONDS=1.0
TICK_LIMIT=200
OHLC_LIMIT=200

# 批量落库配置
TICK_FLUSH_INTERVAL=1.0
TICK_FLUSH_BATCH_SIZE=500
TICK_QUEUE_MAXSIZE=20000
QUOTE_FLUSH_ENABLED=false
QUOTE_FLUSH_INTERVAL=1.0
QUOTE_FLUSH_BATCH_SIZE=200
QUOTE_QUEUE_MAXSIZE=5000
OHLC_FLUSH_INTERVAL=1.0
OHLC_FLUSH_BATCH_SIZE=200
OHLC_QUEUE_MAXSIZE=5000
INTRABAR_ENABLED=true
INTRABAR_FLUSH_INTERVAL=5.0
INTRABAR_FLUSH_BATCH_SIZE=200
INTRABAR_QUEUE_MAXSIZE=10000

# 重试配置
FLUSH_RETRY_ATTEMPTS=3
FLUSH_RETRY_BACKOFF=1.0
CONNECTION_RETRY_ATTEMPTS=5
CONNECTION_RETRY_BACKOFF=2.0

# 监控配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL=30.0
METRICS_UPDATE_INTERVAL=60.0

# 安全配置
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY_HEADER=X-API-Key
ENABLE_AUTH=false  # 生产环境建议设置为 true

# 性能配置
WORKER_THREADS=4
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30.0
KEEP_ALIVE_TIMEOUT=5.0

# 日志配置
LOG_FILE=logs/mt5services.log
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_DAYS=7
LOG_FORMAT=json  # json 或 text

# 开发配置
DEBUG=false
RELOAD=false  # 代码热重载，仅开发环境使用
PROFILING_ENABLED=false

# 外部 API 配置（可选）
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key
POLYGON_API_KEY=your_polygon_key

# 邮件通知配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=admin@example.com

# Sentry 错误监控（可选）
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development  # development, staging, production

# ============================================
# 生产环境注意事项：
# 1. 所有密码和密钥必须使用强密码
# 2. 启用 SSL/TLS 加密
# 3. 设置适当的防火墙规则
# 4. 定期备份数据库
# 5. 监控系统资源使用情况
# ============================================